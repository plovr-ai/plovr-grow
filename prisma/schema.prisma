generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model Tenant {
  id                 String             @id
  name               String
  subscriptionPlan   String             @default("free") @map("subscription_plan")
  subscriptionStatus String             @default("active") @map("subscription_status")
  createdAt          DateTime           @default(now()) @map("created_at")
  updatedAt          DateTime           @updatedAt @map("updated_at")
  company            Company?
  menuCategories     MenuCategory[]
  menuItems          MenuItem[]
  orders             Order[]
  users              User[]
  taxConfigs         TaxConfig[]
  loyaltyConfigs     LoyaltyConfig[]
  loyaltyMembers     LoyaltyMember[]
  pointTransactions  PointTransaction[]
  otpVerifications   OtpVerification[]

  @@map("tenants")
}

model Company {
  id                    String          @id
  tenantId              String          @unique @map("tenant_id")
  slug                  String          @unique
  name                  String
  legalName             String?         @map("legal_name")
  description           String?         @db.Text
  logoUrl               String?         @map("logo_url")
  websiteUrl            String?         @map("website_url")
  supportEmail          String?         @map("support_email")
  supportPhone          String?         @map("support_phone")
  settings              Json?
  status                String          @default("active")
  onboardingStatus      String          @default("not_started") @map("onboarding_status")
  onboardingData        Json?           @map("onboarding_data")
  onboardingCompletedAt DateTime?       @map("onboarding_completed_at")
  createdAt             DateTime        @default(now()) @map("created_at")
  updatedAt             DateTime        @updatedAt @map("updated_at")
  tenant                Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  menuCategories        MenuCategory[]
  menuItems             MenuItem[]
  merchants             Merchant[]
  users                 User[]
  taxConfigs            TaxConfig[]
  loyaltyConfig         LoyaltyConfig?
  loyaltyMembers        LoyaltyMember[]

  @@index([slug])
  @@index([tenantId])
  @@map("companies")
}

model MenuCategory {
  id          String     @id
  tenantId    String     @map("tenant_id")
  companyId   String     @map("company_id")
  name        String
  description String?    @db.Text
  imageUrl    String?    @map("image_url")
  sortOrder   Int        @default(0) @map("sort_order")
  status      String     @default("active")
  createdAt   DateTime   @default(now()) @map("created_at")
  updatedAt   DateTime   @updatedAt @map("updated_at")
  company     Company    @relation(fields: [companyId], references: [id], onDelete: Cascade)
  tenant      Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  menuItems   MenuItem[]

  @@index([companyId])
  @@index([companyId, sortOrder])
  @@index([tenantId])
  @@map("menu_categories")
}

model MenuItem {
  id            String        @id
  tenantId      String        @map("tenant_id")
  companyId     String        @map("company_id")
  categoryId    String        @map("category_id")
  name          String
  description   String?       @db.Text
  price         Decimal       @db.Decimal(10, 2)
  imageUrl      String?       @map("image_url")
  sortOrder     Int           @default(0) @map("sort_order")
  status        String        @default("active")
  options       Json?
  nutrition     Json?
  tags          Json?
  createdAt     DateTime      @default(now()) @map("created_at")
  updatedAt     DateTime      @updatedAt @map("updated_at")
  category      MenuCategory  @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  company       Company       @relation(fields: [companyId], references: [id], onDelete: Cascade)
  tenant        Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  menuItemTaxes MenuItemTax[]

  @@index([categoryId], map: "menu_items_category_id_fkey")
  @@index([companyId, categoryId])
  @@index([companyId])
  @@index([companyId, status])
  @@index([tenantId])
  @@map("menu_items")
}

model Merchant {
  id                String             @id
  companyId         String             @map("company_id")
  slug              String             @unique
  name              String
  description       String?            @db.Text
  address           String?
  city              String?
  state             String?
  zipCode           String?            @map("zip_code")
  country           String             @default("US")
  phone             String?
  email             String?
  logoUrl           String?            @map("logo_url")
  bannerUrl         String?            @map("banner_url")
  businessHours     Json?              @map("business_hours")
  timezone          String             @default("America/New_York")
  currency          String             @default("USD")
  locale            String             @default("en-US")
  taxRate           Decimal            @default(0.0000) @map("tax_rate") @db.Decimal(5, 4)
  status            String             @default("active")
  settings          Json?
  createdAt         DateTime           @default(now()) @map("created_at")
  updatedAt         DateTime           @updatedAt @map("updated_at")
  company           Company            @relation(fields: [companyId], references: [id], onDelete: Cascade)
  orders            Order[]
  merchantTaxRates  MerchantTaxRate[]
  pointTransactions PointTransaction[]

  @@index([companyId])
  @@index([slug])
  @@index([status])
  @@map("merchants")
}

model Order {
  id                String             @id
  tenantId          String             @map("tenant_id")
  merchantId        String?            @map("merchant_id")
  loyaltyMemberId   String?            @map("loyalty_member_id")
  orderNumber       String             @map("order_number")
  customerName      String             @map("customer_name")
  customerPhone     String             @map("customer_phone")
  customerEmail     String?            @map("customer_email")
  orderType         String             @map("order_type")
  status            String             @default("pending")
  items             Json
  subtotal          Decimal            @db.Decimal(10, 2)
  taxAmount         Decimal            @map("tax_amount") @db.Decimal(10, 2)
  tipAmount         Decimal            @default(0.00) @map("tip_amount") @db.Decimal(10, 2)
  deliveryFee       Decimal            @default(0.00) @map("delivery_fee") @db.Decimal(10, 2)
  discount          Decimal            @default(0.00) @db.Decimal(10, 2)
  totalAmount       Decimal            @map("total_amount") @db.Decimal(10, 2)
  notes             String?            @db.Text
  deliveryAddress   Json?              @map("delivery_address")
  scheduledAt       DateTime?          @map("scheduled_at")
  confirmedAt       DateTime?          @map("confirmed_at")
  completedAt       DateTime?          @map("completed_at")
  cancelledAt       DateTime?          @map("cancelled_at")
  cancelReason      String?            @map("cancel_reason")
  createdAt         DateTime           @default(now()) @map("created_at")
  updatedAt         DateTime           @updatedAt @map("updated_at")
  merchant          Merchant?          @relation(fields: [merchantId], references: [id], onDelete: Cascade)
  tenant            Tenant             @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  loyaltyMember     LoyaltyMember?     @relation(fields: [loyaltyMemberId], references: [id], onDelete: SetNull)
  pointTransactions PointTransaction[]

  @@unique([tenantId, orderNumber])
  @@index([merchantId])
  @@index([loyaltyMemberId])
  @@index([tenantId, createdAt])
  @@index([tenantId])
  @@index([tenantId, status])
  @@map("orders")
}

model PasswordResetToken {
  id        String   @id
  email     String
  token     String   @unique
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")

  @@index([email])
  @@index([token])
  @@map("password_reset_tokens")
}

model User {
  id           String    @id
  tenantId     String    @map("tenant_id")
  companyId    String?   @map("company_id")
  email        String
  passwordHash String    @map("password_hash")
  name         String
  role         String    @default("staff")
  status       String    @default("active")
  lastLoginAt  DateTime? @map("last_login_at")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")
  company      Company?  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  tenant       Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, email])
  @@index([companyId])
  @@index([tenantId])
  @@map("users")
}

// ==================== Tax Configuration ====================

model TaxConfig {
  id               String            @id
  tenantId         String            @map("tenant_id")
  companyId        String            @map("company_id")
  name             String
  description      String?           @db.Text
  roundingMethod   String            @default("half_up") @map("rounding_method")
  status           String            @default("active")
  createdAt        DateTime          @default(now()) @map("created_at")
  updatedAt        DateTime          @updatedAt @map("updated_at")
  tenant           Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  company          Company           @relation(fields: [companyId], references: [id], onDelete: Cascade)
  merchantTaxRates MerchantTaxRate[]
  menuItemTaxes    MenuItemTax[]

  @@index([tenantId])
  @@index([companyId])
  @@index([companyId, status])
  @@map("tax_configs")
}

model MerchantTaxRate {
  id          String    @id
  merchantId  String    @map("merchant_id")
  taxConfigId String    @map("tax_config_id")
  rate        Decimal   @db.Decimal(5, 4)
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")
  merchant    Merchant  @relation(fields: [merchantId], references: [id], onDelete: Cascade)
  taxConfig   TaxConfig @relation(fields: [taxConfigId], references: [id], onDelete: Cascade)

  @@unique([merchantId, taxConfigId])
  @@index([merchantId])
  @@index([taxConfigId])
  @@map("merchant_tax_rates")
}

model MenuItemTax {
  id          String    @id
  menuItemId  String    @map("menu_item_id")
  taxConfigId String    @map("tax_config_id")
  createdAt   DateTime  @default(now()) @map("created_at")
  menuItem    MenuItem  @relation(fields: [menuItemId], references: [id], onDelete: Cascade)
  taxConfig   TaxConfig @relation(fields: [taxConfigId], references: [id], onDelete: Cascade)

  @@unique([menuItemId, taxConfigId])
  @@index([menuItemId])
  @@index([taxConfigId])
  @@map("menu_item_taxes")
}

// ==================== Loyalty System ====================

model LoyaltyConfig {
  id              String   @id
  tenantId        String   @map("tenant_id")
  companyId       String   @unique @map("company_id")
  pointsPerDollar Decimal  @default(1) @map("points_per_dollar") @db.Decimal(5, 2)
  status          String   @default("active")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  tenant  Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@map("loyalty_configs")
}

model LoyaltyMember {
  id          String    @id
  tenantId    String    @map("tenant_id")
  companyId   String    @map("company_id")
  phone       String
  email       String?
  name        String?
  points      Int       @default(0)
  totalOrders Int       @default(0) @map("total_orders")
  totalSpent  Decimal   @default(0.00) @map("total_spent") @db.Decimal(10, 2)
  lastOrderAt DateTime? @map("last_order_at")
  enrolledAt  DateTime  @default(now()) @map("enrolled_at")
  status      String    @default("active")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  company           Company            @relation(fields: [companyId], references: [id], onDelete: Cascade)
  tenant            Tenant             @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  pointTransactions PointTransaction[]
  orders            Order[]

  @@unique([tenantId, companyId, phone])
  @@index([phone])
  @@index([companyId])
  @@index([tenantId])
  @@map("loyalty_members")
}

model PointTransaction {
  id            String   @id
  tenantId      String   @map("tenant_id")
  memberId      String   @map("member_id")
  merchantId    String?  @map("merchant_id")
  orderId       String?  @map("order_id")
  type          String
  points        Int
  balanceBefore Int      @map("balance_before")
  balanceAfter  Int      @map("balance_after")
  description   String?
  createdAt     DateTime @default(now()) @map("created_at")

  tenant        Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  loyaltyMember LoyaltyMember @relation(fields: [memberId], references: [id], onDelete: Cascade)
  merchant      Merchant?     @relation(fields: [merchantId], references: [id], onDelete: SetNull)
  order         Order?        @relation(fields: [orderId], references: [id], onDelete: SetNull)

  @@index([tenantId])
  @@index([memberId])
  @@index([orderId])
  @@map("point_transactions")
}

model OtpVerification {
  id         String    @id
  tenantId   String    @map("tenant_id")
  phone      String
  code       String
  purpose    String
  attempts   Int       @default(0)
  expiresAt  DateTime  @map("expires_at")
  verifiedAt DateTime? @map("verified_at")
  createdAt  DateTime  @default(now()) @map("created_at")

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, phone, purpose])
  @@index([tenantId])
  @@index([expiresAt])
  @@map("otp_verifications")
}
