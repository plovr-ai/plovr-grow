generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model Tenant {
  id                      String                 @id
  name                    String
  subscriptionPlan        String                 @default("free") @map("subscription_plan")
  subscriptionStatus      String                 @default("active") @map("subscription_status")
  stripeConnectStatus     String?                @map("stripe_connect_status")
  deleted                 Boolean                @default(false)
  createdAt               DateTime               @default(now()) @map("created_at")
  updatedAt               DateTime               @updatedAt @map("updated_at")
  company                 Company?
  stripeConnectAccount    StripeConnectAccount?
  menus                   Menu[]
  menuCategories          MenuCategory[]
  menuItems               MenuItem[]
  orders                  Order[]
  users                   User[]
  taxConfigs              TaxConfig[]
  loyaltyConfigs          LoyaltyConfig[]
  loyaltyMembers          LoyaltyMember[]
  pointTransactions       PointTransaction[]
  otpVerifications        OtpVerification[]
  featuredItems           FeaturedItem[]
  cateringLeads           CateringLead[]
  cateringOrders          CateringOrder[]
  invoices                Invoice[]
  giftCards               GiftCard[]
  giftCardTransactions    GiftCardTransaction[]
  orderSequences          OrderSequence[]
  companyOrderSequences   CompanyOrderSequence[]
  cateringOrderSequences  CateringOrderSequence[]
  invoiceSequences        InvoiceSequence[]
  payments                Payment[]
  stripeCustomers         StripeCustomer[]
  subscription            Subscription?
  merchants               Merchant[]
  passwordResetTokens     PasswordResetToken[]
  menuCategoryItems       MenuCategoryItem[]
  menuItemTaxes           MenuItemTax[]

  @@map("tenants")
}

model Company {
  id                    String          @id
  tenantId              String          @unique @map("tenant_id")
  slug                  String          @unique
  name                  String
  legalName             String?         @map("legal_name")
  description           String?         @db.Text
  logoUrl               String?         @map("logo_url")
  websiteUrl            String?         @map("website_url")
  supportEmail          String?         @map("support_email")
  supportPhone          String?         @map("support_phone")
  currency              String          @default("USD")
  locale                String          @default("en-US")
  timezone              String          @default("America/New_York")
  settings              Json?
  status                String          @default("active")
  onboardingStatus      String          @default("not_started") @map("onboarding_status")
  onboardingData        Json?           @map("onboarding_data")
  onboardingCompletedAt DateTime?       @map("onboarding_completed_at")
  deleted               Boolean         @default(false)
  createdAt             DateTime        @default(now()) @map("created_at")
  updatedAt             DateTime        @updatedAt @map("updated_at")
  tenant                Tenant          @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  menus                 Menu[]
  menuCategories        MenuCategory[]
  menuItems             MenuItem[]
  merchants             Merchant[]
  users                 User[]
  taxConfigs            TaxConfig[]
  loyaltyConfig         LoyaltyConfig?
  loyaltyMembers        LoyaltyMember[]
  featuredItems         FeaturedItem[]
  orders                Order[]
  giftCards             GiftCard[]
  companyOrderSequences CompanyOrderSequence[]
  stripeCustomers       StripeCustomer[]

  @@index([slug])
  @@index([tenantId])
  @@map("companies")
}

model Menu {
  id          String         @id
  tenantId    String         @map("tenant_id")
  companyId   String         @map("company_id")
  name        String
  description String?        @db.Text
  sortOrder   Int            @default(0) @map("sort_order")
  status      String         @default("active")
  deleted     Boolean        @default(false)
  createdAt   DateTime       @default(now()) @map("created_at")
  updatedAt   DateTime       @updatedAt @map("updated_at")
  tenant      Tenant         @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  company     Company        @relation(fields: [companyId], references: [id], onDelete: Restrict)
  categories  MenuCategory[]

  @@index([tenantId])
  @@index([companyId])
  @@index([companyId, sortOrder])
  @@map("menus")
}

model MenuCategory {
  id            String             @id
  tenantId      String             @map("tenant_id")
  companyId     String             @map("company_id")
  menuId        String             @map("menu_id")
  name          String
  description   String?            @db.Text
  imageUrl      String?            @map("image_url")
  sortOrder     Int                @default(0) @map("sort_order")
  status        String             @default("active")
  deleted       Boolean            @default(false)
  createdAt     DateTime           @default(now()) @map("created_at")
  updatedAt     DateTime           @updatedAt @map("updated_at")
  company       Company            @relation(fields: [companyId], references: [id], onDelete: Restrict)
  tenant        Tenant             @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  menu          Menu               @relation(fields: [menuId], references: [id], onDelete: Restrict)
  categoryItems MenuCategoryItem[]

  @@index([companyId])
  @@index([companyId, sortOrder])
  @@index([tenantId])
  @@index([menuId])
  @@map("menu_categories")
}

model MenuItem {
  id            String             @id
  tenantId      String             @map("tenant_id")
  companyId     String             @map("company_id")
  name          String
  description   String?            @db.Text
  price         Decimal            @db.Decimal(10, 2)
  imageUrl      String?            @map("image_url")
  status        String             @default("active")
  modifiers     Json?
  nutrition     Json?
  tags          Json?
  deleted       Boolean            @default(false)
  createdAt     DateTime           @default(now()) @map("created_at")
  updatedAt     DateTime           @updatedAt @map("updated_at")
  company       Company            @relation(fields: [companyId], references: [id], onDelete: Restrict)
  tenant        Tenant             @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  menuItemTaxes MenuItemTax[]
  categories    MenuCategoryItem[]
  featuredItems FeaturedItem[]

  @@index([companyId])
  @@index([companyId, status])
  @@index([tenantId])
  @@map("menu_items")
}

model MenuCategoryItem {
  id         String       @id
  tenantId   String       @map("tenant_id")
  categoryId String       @map("category_id")
  menuItemId String       @map("menu_item_id")
  sortOrder  Int          @default(0) @map("sort_order")
  deleted    Boolean      @default(false)
  createdAt  DateTime     @default(now()) @map("created_at")
  updatedAt  DateTime     @updatedAt @map("updated_at")
  tenant     Tenant       @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  category   MenuCategory @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  menuItem   MenuItem     @relation(fields: [menuItemId], references: [id], onDelete: Restrict)

  @@unique([categoryId, menuItemId])
  @@index([tenantId])
  @@index([categoryId])
  @@index([menuItemId])
  @@map("menu_category_items")
}

model Merchant {
  id                String             @id
  tenantId          String             @map("tenant_id")
  companyId         String             @map("company_id")
  slug              String             @unique
  name              String
  description       String?            @db.Text
  address           String?
  city              String?
  state             String?
  zipCode           String?            @map("zip_code")
  country           String             @default("US")
  phone             String?
  email             String?
  logoUrl           String?            @map("logo_url")
  bannerUrl         String?            @map("banner_url")
  businessHours     Json?              @map("business_hours")
  timezone          String             @default("America/New_York")
  currency          String             @default("USD")
  locale            String             @default("en-US")
  status            String             @default("active")
  settings          Json?
  deleted           Boolean            @default(false)
  createdAt         DateTime           @default(now()) @map("created_at")
  updatedAt         DateTime           @updatedAt @map("updated_at")
  tenant            Tenant             @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  company           Company            @relation(fields: [companyId], references: [id], onDelete: Restrict)
  orders            Order[]
  merchantTaxRates  MerchantTaxRate[]
  pointTransactions PointTransaction[]
  cateringLeads     CateringLead[]
  cateringOrders    CateringOrder[]
  orderSequences         OrderSequence[]
  cateringOrderSequences CateringOrderSequence[]

  @@index([tenantId])
  @@index([companyId])
  @@index([slug])
  @@index([status])
  @@map("merchants")
}

model Order {
  id                    String                 @id
  tenantId              String                 @map("tenant_id")
  companyId             String                 @map("company_id")
  merchantId            String?                @map("merchant_id")
  loyaltyMemberId       String?                @map("loyalty_member_id")
  orderNumber           String                 @map("order_number")
  customerFirstName     String                 @map("customer_first_name")
  customerLastName      String                 @map("customer_last_name")
  customerPhone         String                 @map("customer_phone")
  customerEmail         String?                @map("customer_email")
  orderMode             String                 @map("order_mode")
  salesChannel          String                 @default("online_order") @map("sales_channel")
  status                String                 @default("created")
  fulfillmentStatus     String                 @default("pending") @map("fulfillment_status")
  items                 Json
  subtotal              Decimal                @db.Decimal(10, 2)
  taxAmount             Decimal                @map("tax_amount") @db.Decimal(10, 2)
  tipAmount             Decimal                @default(0.00) @map("tip_amount") @db.Decimal(10, 2)
  deliveryFee           Decimal                @default(0.00) @map("delivery_fee") @db.Decimal(10, 2)
  discount              Decimal                @default(0.00) @db.Decimal(10, 2)
  giftCardPayment       Decimal                @default(0.00) @map("gift_card_payment") @db.Decimal(10, 2)
  cashPayment           Decimal                @default(0.00) @map("cash_payment") @db.Decimal(10, 2)
  totalAmount           Decimal                @map("total_amount") @db.Decimal(10, 2)
  notes                 String?                @db.Text
  deliveryAddress       Json?                  @map("delivery_address")
  scheduledAt           DateTime?              @map("scheduled_at")
  paidAt                DateTime?              @map("paid_at")
  confirmedAt           DateTime?              @map("confirmed_at")
  preparingAt           DateTime?              @map("preparing_at")
  readyAt               DateTime?              @map("ready_at")
  fulfilledAt           DateTime?              @map("fulfilled_at")
  cancelledAt           DateTime?              @map("cancelled_at")
  cancelReason          String?                @map("cancel_reason")
  deleted               Boolean                @default(false)
  createdAt             DateTime               @default(now()) @map("created_at")
  updatedAt             DateTime               @updatedAt @map("updated_at")
  company               Company                @relation(fields: [companyId], references: [id], onDelete: Restrict)
  merchant              Merchant?              @relation(fields: [merchantId], references: [id], onDelete: Restrict)
  tenant                Tenant                 @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  loyaltyMember         LoyaltyMember?         @relation(fields: [loyaltyMemberId], references: [id], onDelete: Restrict)
  pointTransactions     PointTransaction[]
  giftCardPurchase      GiftCard?              @relation("GiftCardPurchase")
  giftCardRedemptions   GiftCardTransaction[]  @relation("GiftCardRedemption")
  payments              Payment[]

  @@unique([tenantId, orderNumber])
  @@index([companyId])
  @@index([merchantId])
  @@index([loyaltyMemberId])
  @@index([tenantId, createdAt])
  @@index([tenantId])
  @@index([tenantId, status])
  @@index([tenantId, fulfillmentStatus])
  @@index([tenantId, salesChannel])
  @@map("orders")
}

model PasswordResetToken {
  id        String   @id
  tenantId  String   @map("tenant_id")
  email     String
  token     String   @unique
  expiresAt DateTime @map("expires_at")
  deleted   Boolean  @default(false)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Restrict)

  @@index([tenantId])
  @@index([email])
  @@index([token])
  @@map("password_reset_tokens")
}

model User {
  id           String    @id
  tenantId     String    @map("tenant_id")
  companyId    String?   @map("company_id")
  email        String
  passwordHash String    @map("password_hash")
  name         String
  role         String    @default("staff")
  status       String    @default("active")
  lastLoginAt  DateTime? @map("last_login_at")
  deleted      Boolean   @default(false)
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")
  company      Company?  @relation(fields: [companyId], references: [id], onDelete: Restrict)
  tenant       Tenant    @relation(fields: [tenantId], references: [id], onDelete: Restrict)

  @@unique([tenantId, email])
  @@index([companyId])
  @@index([tenantId])
  @@map("users")
}

// ==================== Tax Configuration ====================

model TaxConfig {
  id               String            @id
  tenantId         String            @map("tenant_id")
  companyId        String            @map("company_id")
  name             String
  description      String?           @db.Text
  roundingMethod   String            @default("half_up") @map("rounding_method")
  status           String            @default("active")
  deleted          Boolean           @default(false)
  createdAt        DateTime          @default(now()) @map("created_at")
  updatedAt        DateTime          @updatedAt @map("updated_at")
  tenant           Tenant            @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  company          Company           @relation(fields: [companyId], references: [id], onDelete: Restrict)
  merchantTaxRates MerchantTaxRate[]
  menuItemTaxes    MenuItemTax[]

  @@index([tenantId])
  @@index([companyId])
  @@index([companyId, status])
  @@map("tax_configs")
}

model MerchantTaxRate {
  id          String    @id
  merchantId  String    @map("merchant_id")
  taxConfigId String    @map("tax_config_id")
  rate        Decimal   @db.Decimal(5, 4)
  deleted     Boolean   @default(false)
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")
  merchant    Merchant  @relation(fields: [merchantId], references: [id], onDelete: Restrict)
  taxConfig   TaxConfig @relation(fields: [taxConfigId], references: [id], onDelete: Restrict)

  @@unique([merchantId, taxConfigId])
  @@index([merchantId])
  @@index([taxConfigId])
  @@map("merchant_tax_rates")
}

model MenuItemTax {
  id          String    @id
  tenantId    String    @map("tenant_id")
  menuItemId  String    @map("menu_item_id")
  taxConfigId String    @map("tax_config_id")
  deleted     Boolean   @default(false)
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")
  tenant      Tenant    @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  menuItem    MenuItem  @relation(fields: [menuItemId], references: [id], onDelete: Restrict)
  taxConfig   TaxConfig @relation(fields: [taxConfigId], references: [id], onDelete: Restrict)

  @@unique([menuItemId, taxConfigId])
  @@index([tenantId])
  @@index([menuItemId])
  @@index([taxConfigId])
  @@map("menu_item_taxes")
}

// ==================== Loyalty System ====================

model LoyaltyConfig {
  id              String   @id
  tenantId        String   @map("tenant_id")
  companyId       String   @unique @map("company_id")
  pointsPerDollar Decimal  @default(1) @map("points_per_dollar") @db.Decimal(5, 2)
  status          String   @default("active")
  deleted         Boolean  @default(false)
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  tenant  Tenant  @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  company Company @relation(fields: [companyId], references: [id], onDelete: Restrict)

  @@index([tenantId])
  @@map("loyalty_configs")
}

model LoyaltyMember {
  id          String    @id
  tenantId    String    @map("tenant_id")
  companyId   String    @map("company_id")
  phone       String
  email       String?
  firstName   String?   @map("first_name")
  lastName    String?   @map("last_name")
  points      Int       @default(0)
  totalOrders Int       @default(0) @map("total_orders")
  totalSpent  Decimal   @default(0.00) @map("total_spent") @db.Decimal(10, 2)
  lastOrderAt DateTime? @map("last_order_at")
  enrolledAt  DateTime  @default(now()) @map("enrolled_at")
  deleted     Boolean   @default(false)
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  company           Company            @relation(fields: [companyId], references: [id], onDelete: Restrict)
  tenant            Tenant             @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  pointTransactions PointTransaction[]
  orders            Order[]
  stripeCustomer    StripeCustomer?

  @@unique([tenantId, companyId, phone])
  @@index([phone])
  @@index([companyId])
  @@index([tenantId])
  @@map("loyalty_members")
}

model PointTransaction {
  id            String   @id
  tenantId      String   @map("tenant_id")
  memberId      String   @map("member_id")
  merchantId    String?  @map("merchant_id")
  orderId       String?  @map("order_id")
  type          String
  points        Int
  balanceBefore Int      @map("balance_before")
  balanceAfter  Int      @map("balance_after")
  description   String?
  deleted       Boolean  @default(false)
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  tenant        Tenant        @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  loyaltyMember LoyaltyMember @relation(fields: [memberId], references: [id], onDelete: Restrict)
  merchant      Merchant?     @relation(fields: [merchantId], references: [id], onDelete: Restrict)
  order         Order?        @relation(fields: [orderId], references: [id], onDelete: Restrict)

  @@unique([tenantId, orderId, type], map: "point_transactions_tenant_order_type_unique")
  @@index([tenantId])
  @@index([memberId])
  @@map("point_transactions")
}

model OtpVerification {
  id         String    @id
  tenantId   String    @map("tenant_id")
  phone      String
  code       String
  purpose    String
  attempts   Int       @default(0)
  expiresAt  DateTime  @map("expires_at")
  verifiedAt DateTime? @map("verified_at")
  deleted    Boolean   @default(false)
  createdAt  DateTime  @default(now()) @map("created_at")
  updatedAt  DateTime  @updatedAt @map("updated_at")

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Restrict)

  @@unique([tenantId, phone, purpose])
  @@index([tenantId])
  @@index([expiresAt])
  @@map("otp_verifications")
}

// ==================== Featured Items ====================

model FeaturedItem {
  id         String   @id
  tenantId   String   @map("tenant_id")
  companyId  String   @map("company_id")
  menuItemId String   @map("menu_item_id")
  sortOrder  Int      @default(0) @map("sort_order")
  deleted    Boolean  @default(false)
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  tenant   Tenant   @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  company  Company  @relation(fields: [companyId], references: [id], onDelete: Restrict)
  menuItem MenuItem @relation(fields: [menuItemId], references: [id], onDelete: Restrict)

  @@unique([companyId, menuItemId])
  @@index([tenantId])
  @@index([companyId])
  @@map("featured_items")
}

// ==================== Catering ====================

model CateringLead {
  id         String   @id
  tenantId   String   @map("tenant_id")
  merchantId String   @map("merchant_id")
  firstName  String   @map("first_name")
  lastName   String   @map("last_name")
  phone      String
  email      String
  notes      String?  @db.Text
  status     String   @default("pending")
  deleted    Boolean  @default(false)
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  merchant      Merchant       @relation(fields: [merchantId], references: [id], onDelete: Restrict)
  tenant        Tenant         @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  cateringOrder CateringOrder?

  @@index([tenantId])
  @@index([merchantId])
  @@index([merchantId, status])
  @@index([merchantId, createdAt])
  @@map("catering_leads")
}

model CateringOrder {
  id                String    @id
  tenantId          String    @map("tenant_id")
  merchantId        String    @map("merchant_id")
  leadId            String?   @unique @map("lead_id")

  // Customer info
  customerFirstName String    @map("customer_first_name")
  customerLastName  String    @map("customer_last_name")
  customerPhone     String    @map("customer_phone")
  customerEmail     String    @map("customer_email")

  // Event details
  eventDate         DateTime  @map("event_date")
  eventTime         String    @map("event_time")
  guestCount        Int       @map("guest_count")
  eventType         String?   @map("event_type")
  eventAddress      String?   @map("event_address") @db.Text
  specialRequests   String?   @map("special_requests") @db.Text

  // Order details
  orderNumber       String    @unique @map("order_number")
  items             Json
  subtotal          Decimal   @db.Decimal(10, 2)
  taxAmount         Decimal   @map("tax_amount") @db.Decimal(10, 2)
  serviceCharge     Decimal   @default(0.00) @map("service_charge") @db.Decimal(10, 2)
  totalAmount       Decimal   @map("total_amount") @db.Decimal(10, 2)

  // Status
  status            String    @default("draft")
  notes             String?   @db.Text

  // Timestamps
  deleted           Boolean   @default(false)
  createdAt         DateTime  @default(now()) @map("created_at")
  updatedAt         DateTime  @updatedAt @map("updated_at")
  sentAt            DateTime? @map("sent_at")
  paidAt            DateTime? @map("paid_at")

  // Relations
  tenant            Tenant        @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  merchant          Merchant      @relation(fields: [merchantId], references: [id], onDelete: Restrict)
  lead              CateringLead? @relation(fields: [leadId], references: [id], onDelete: Restrict)
  invoice           Invoice?

  @@index([tenantId])
  @@index([merchantId])
  @@index([status])
  @@index([merchantId, status])
  @@index([merchantId, eventDate])
  @@map("catering_orders")
}

model Invoice {
  id              String    @id
  tenantId        String    @map("tenant_id")
  cateringOrderId String    @unique @map("catering_order_id")
  invoiceNumber   String    @unique @map("invoice_number")

  // Payment details
  amount          Decimal   @db.Decimal(10, 2)
  status          String    @default("unpaid")
  dueDate         DateTime  @map("due_date")
  paymentLink     String?   @map("payment_link")

  // Email tracking
  sentAt          DateTime? @map("sent_at")
  openedAt        DateTime? @map("opened_at")
  paidAt          DateTime? @map("paid_at")

  deleted         Boolean   @default(false)
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  tenant          Tenant        @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  cateringOrder   CateringOrder @relation(fields: [cateringOrderId], references: [id], onDelete: Restrict)

  @@index([tenantId])
  @@index([status])
  @@map("invoices")
}

// ==================== Gift Card System ====================

model GiftCard {
  id              String                @id
  tenantId        String                @map("tenant_id")
  companyId       String                @map("company_id")
  cardNumber      String                @unique @map("card_number")
  initialAmount   Decimal               @map("initial_amount") @db.Decimal(10, 2)
  currentBalance  Decimal               @map("current_balance") @db.Decimal(10, 2)
  purchaseOrderId String                @unique @map("purchase_order_id")
  deleted         Boolean               @default(false)
  createdAt       DateTime              @default(now()) @map("created_at")
  updatedAt       DateTime              @updatedAt @map("updated_at")

  tenant        Tenant                  @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  company       Company                 @relation(fields: [companyId], references: [id], onDelete: Restrict)
  purchaseOrder Order                   @relation("GiftCardPurchase", fields: [purchaseOrderId], references: [id], onDelete: Restrict)
  transactions  GiftCardTransaction[]

  @@index([tenantId])
  @@index([companyId])
  @@index([cardNumber])
  @@map("gift_cards")
}

model GiftCardTransaction {
  id            String   @id
  tenantId      String   @map("tenant_id")
  giftCardId    String   @map("gift_card_id")
  orderId       String?  @map("order_id")
  type          String   // purchase, redemption, refund
  amount        Decimal  @db.Decimal(10, 2)
  balanceBefore Decimal  @map("balance_before") @db.Decimal(10, 2)
  balanceAfter  Decimal  @map("balance_after") @db.Decimal(10, 2)
  deleted       Boolean  @default(false)
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  tenant   Tenant    @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  giftCard GiftCard  @relation(fields: [giftCardId], references: [id], onDelete: Restrict)
  order    Order?    @relation("GiftCardRedemption", fields: [orderId], references: [id], onDelete: Restrict)

  @@index([tenantId])
  @@index([giftCardId])
  @@index([orderId])
  @@map("gift_card_transactions")
}

// ==================== Sequence Tables ====================

/// Order sequence table for atomic sequence generation (merchant-level)
model OrderSequence {
  id         String   @id
  tenantId   String   @map("tenant_id")
  merchantId String   @map("merchant_id")
  date       String   // Format: "2026-01-27"
  sequence   Int      @default(0)
  deleted    Boolean  @default(false)
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  tenant   Tenant   @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  merchant Merchant @relation(fields: [merchantId], references: [id], onDelete: Restrict)

  @@unique([tenantId, merchantId, date])
  @@index([tenantId])
  @@index([merchantId])
  @@index([date])
  @@map("order_sequences")
}

/// Company-level order sequence (for gift card orders)
model CompanyOrderSequence {
  id        String   @id
  tenantId  String   @map("tenant_id")
  companyId String   @map("company_id")
  date      String   // Format: "2026-01-27"
  sequence  Int      @default(0)
  deleted   Boolean  @default(false)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  tenant  Tenant  @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  company Company @relation(fields: [companyId], references: [id], onDelete: Restrict)

  @@unique([tenantId, companyId, date])
  @@index([tenantId])
  @@index([companyId])
  @@index([date])
  @@map("company_order_sequences")
}

/// Catering order sequence table
model CateringOrderSequence {
  id         String   @id
  tenantId   String   @map("tenant_id")
  merchantId String   @map("merchant_id")
  date       String   // Format: "2026-01-27"
  sequence   Int      @default(0)
  deleted    Boolean  @default(false)
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  tenant   Tenant   @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  merchant Merchant @relation(fields: [merchantId], references: [id], onDelete: Restrict)

  @@unique([tenantId, merchantId, date])
  @@index([tenantId])
  @@index([merchantId])
  @@index([date])
  @@map("catering_order_sequences")
}

/// Invoice sequence table (tenant-level, never resets)
model InvoiceSequence {
  id        String   @id
  tenantId  String   @unique @map("tenant_id")
  sequence  Int      @default(0)
  deleted   Boolean  @default(false)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Restrict)

  @@index([tenantId])
  @@map("invoice_sequences")
}

// ==================== Payment System ====================

/// Payment record for Stripe payments
model Payment {
  id                    String    @id
  tenantId              String    @map("tenant_id")
  orderId               String    @map("order_id")

  // Stripe fields
  stripePaymentIntentId String    @unique @map("stripe_payment_intent_id")
  stripeCustomerId      String?   @map("stripe_customer_id")
  stripeAccountId       String?   @map("stripe_account_id")

  // Payment info
  amount                Decimal   @db.Decimal(10, 2)
  currency              String    @default("USD")
  status                String    @default("pending") // pending, processing, succeeded, failed, canceled
  paymentMethod         String?   @map("payment_method") // card, apple_pay, google_pay

  // Card details (populated after successful payment)
  cardBrand             String?   @map("card_brand") // visa, mastercard, amex
  cardLast4             String?   @map("card_last4")

  // Failure info
  failureCode           String?   @map("failure_code")
  failureMessage        String?   @map("failure_message")

  // Timestamps
  paidAt                DateTime? @map("paid_at")
  deleted               Boolean   @default(false)
  createdAt             DateTime  @default(now()) @map("created_at")
  updatedAt             DateTime  @updatedAt @map("updated_at")

  // Relations
  tenant                Tenant    @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  order                 Order     @relation(fields: [orderId], references: [id], onDelete: Restrict)

  @@index([tenantId])
  @@index([orderId])
  @@index([stripePaymentIntentId])
  @@index([status])
  @@map("payments")
}

/// Stripe customer mapping for saved cards
model StripeCustomer {
  id                String   @id
  tenantId          String   @map("tenant_id")
  companyId         String   @map("company_id")
  loyaltyMemberId   String   @unique @map("loyalty_member_id")
  stripeCustomerId  String   @unique @map("stripe_customer_id")
  deleted           Boolean  @default(false)
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")

  tenant        Tenant        @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  company       Company       @relation(fields: [companyId], references: [id], onDelete: Restrict)
  loyaltyMember LoyaltyMember @relation(fields: [loyaltyMemberId], references: [id], onDelete: Restrict)

  @@index([tenantId])
  @@index([companyId])
  @@index([stripeCustomerId])
  @@map("stripe_customers")
}

model StripeConnectAccount {
  id                    String    @id
  tenantId              String    @unique @map("tenant_id")
  stripeAccountId       String    @unique @map("stripe_account_id")

  accessToken           String?   @map("access_token")
  refreshToken          String?   @map("refresh_token")
  scope                 String?

  chargesEnabled        Boolean   @default(false) @map("charges_enabled")
  payoutsEnabled        Boolean   @default(false) @map("payouts_enabled")
  detailsSubmitted      Boolean   @default(false) @map("details_submitted")

  connectedAt           DateTime? @map("connected_at")
  disconnectedAt        DateTime? @map("disconnected_at")
  deleted               Boolean   @default(false)
  createdAt             DateTime  @default(now()) @map("created_at")
  updatedAt             DateTime  @updatedAt @map("updated_at")

  tenant                Tenant    @relation(fields: [tenantId], references: [id], onDelete: Restrict)

  @@index([stripeAccountId])
  @@map("stripe_connect_accounts")
}

// ==================== Subscription System ====================

/// Subscription record for tenant-level billing
model Subscription {
  id                      String    @id
  tenantId                String    @unique @map("tenant_id")

  // Stripe references
  stripeCustomerId        String    @unique @map("stripe_customer_id")
  stripeSubscriptionId    String?   @unique @map("stripe_subscription_id")
  stripePriceId           String?   @map("stripe_price_id")

  // Status: incomplete | trialing | active | past_due | canceled | unpaid | paused
  status                  String    @default("incomplete")

  // Plan: free | standard
  plan                    String    @default("standard")

  // Billing cycle
  currentPeriodStart      DateTime? @map("current_period_start")
  currentPeriodEnd        DateTime? @map("current_period_end")

  // Trial
  trialStart              DateTime? @map("trial_start")
  trialEnd                DateTime? @map("trial_end")

  // Cancellation
  cancelAtPeriodEnd       Boolean   @default(false) @map("cancel_at_period_end")
  canceledAt              DateTime? @map("canceled_at")

  // Grace period for past_due
  gracePeriodEnd          DateTime? @map("grace_period_end")

  // Timestamps
  deleted                 Boolean   @default(false)
  createdAt               DateTime  @default(now()) @map("created_at")
  updatedAt               DateTime  @updatedAt @map("updated_at")

  // Relations
  tenant                  Tenant    @relation(fields: [tenantId], references: [id], onDelete: Restrict)

  @@index([status])
  @@map("subscriptions")
}
